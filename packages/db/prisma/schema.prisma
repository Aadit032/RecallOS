generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
  chats     Chat[]
  projects  Project[]
  memories Memory[]
}

model Memory {
  id              String @id @default(uuid())
  fact           String
  importance      Int?
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now())
  lastUsedAt      DateTime?

  userId          String
  user     User   @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum DocumentStatus {
  UPLOADED
  QUEUED
  PARSING
  PROCESSING
  PARSED
  EMBEDDING
  INDEXED
  COMPLETED
  READY
  FAILED
}

model Document {
  id              String         @id @default(uuid())
  title           String
  content         String?
  mimeType        String         @default("application/pdf")
  modality        String         @default("pdf")
  ObjectKey       String         @unique
  status          DocumentStatus @default(UPLOADED)
  streamMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  chunkSets ParsedChunkSet[]

  @@index([userId])
}

model ParsedChunkSet {
  id         String   @id @default(uuid())
  modality   String
  status     String   @default("PARSED")
  createdAt  DateTime @default(now())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  chunks ParsedChunk[]

  @@index([documentId])
}

model ParsedChunk {
  id        String   @id @default(uuid())
  text      String
  metadata  Json?

  chunkSetId String
  chunkSet   ParsedChunkSet @relation(fields: [chunkSetId], references: [id], onDelete: Cascade)

  @@index([chunkSetId])
}

model Project {
  id           String   @id @default(uuid())
  name         String
  systemPrompt String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats  Chat[]

  @@index([userId])
}

model Chat {
  id        String   @id @default(uuid())
  title     String   @default("New chat")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  summary   String?
  lastSummaryCount Int @default(0)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

model Message {
  id           String   @id @default(uuid())
  role         String
  content      String
  sourceChunks Json?
  createdAt    DateTime @default(now())

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}
