# Legacy single-stream (backward compat)
CONSUMER_GROUP=embed-workers
WORKER_ID=worker-1
STREAM_NAME=recallos
GROUP_NAME=embed-workers

# Multimodal streams
FILES_STREAM=files_stream
FILES_GROUP=files-workers
PDF_STREAM=pdf_stream
PDF_GROUP=pdf-workers
IMAGE_STREAM=image_stream
IMAGE_GROUP=image-workers
AUDIO_STREAM=audio_stream
AUDIO_GROUP=audio-workers
VIDEO_STREAM=video_stream
VIDEO_GROUP=video-workers
SCENE_STREAM=scene_stream
SCENE_GROUP=scene-workers
EMBED_STREAM=embed_stream
EMBED_GROUP=embedding-workers
DLQ_STREAM=dlq_stream
DLQ_GROUP=dlq-workers

# DB / storage
DATABASE_URL="postgresql://postgres:password@localhost:5432/recallOs"
AWS_BUCKET_NAME=recallos
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESSKEYID=admin
MINIO_SECRET_ACCESS_KEY=password123

# LlamaCloud parsing
LLAMA_CLOUD_API_KEY=your-LLAMA_CLOUD_API_KEY

# Models / APIs
OPENROUTER_API_KEY=your-OPENROUTER_API_KEY
CONTEXT_MODEL=openrouter/free
VISION_MODEL=openai/gpt-4o-mini
WHISPER_MODEL=openai/whisper-large-v3
# Video scene detection (ffmpeg scene score threshold 0–1)
SCENE_THRESHOLD=0.35
MAX_SCENE_SEC=45
MIN_SCENE_SEC=1.5
HF_TOKEN=your-HF_TOKEN
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# Qdrant
HOST=localhost
COLLECTION=recallos
DENSE_DIM=384

# Langfuse tracing (same project keys as backend)
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://cloud.langfuse.com"
LANGFUSE_TRACING_ENVIRONMENT="development"
LANGFUSE_TRACING_ENABLED="true"